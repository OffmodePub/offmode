# ───────────────────────────────────────────────────────────────
# 환경변수 통합 템플릿 (실제 .env 파일은 절대 커밋 금지)
#
# 실제 .env 파일은 로드 위치 차이로 두 곳에 분리해서 둡니다:
#   1) 루트 .env       ← Expo 앱 + 로컬 도구 (EXPO_PUBLIC_*, SLACK_*)
#                        Expo가 프로젝트 루트 .env 를 자동 로드
#                        (EXPO_PUBLIC_* 만 앱 번들에 노출)
#   2) backend/.env    ← Spring Boot prod (DB_*, R2_*, JWT_*, CORS_*)
#                        EC2 systemd/docker 에서 export 해 사용
#
# 이 템플릿(.env.example)은 양쪽에 들어갈 변수를 한 파일로 정리한 것입니다.
# 아래 [1]/[2] 섹션을 각각의 실제 .env 파일로 복사한 뒤, 필요한 항목의 주석(#)을 해제하고 값을 채워주세요.
# ───────────────────────────────────────────────────────────────


# ===============================================================
# [1] 루트 .env 로 복사 — Expo 앱 + 로컬 도구
# ===============================================================

# ── Expo 공개 API 설정 ─────────────────────────────────────────

# 개발 환경에서 전체 API URL을 그대로 덮어쓸 때 사용합니다.
# 비워두면 아래 EXPO_PUBLIC_DEV_API_HOST/PORT 또는 플랫폼 기본값 사용.
#EXPO_PUBLIC_API_BASE_URL=http://192.168.0.10:8080

# 개발 환경 host/port. EXPO_PUBLIC_API_BASE_URL이 비어 있을 때만 사용됩니다.
# iOS 시뮬레이터 기본값: localhost
# Android 에뮬레이터 기본값: 10.0.2.2
# 실기기 테스트: 백엔드가 실행 중인 PC의 LAN IP를 넣으세요.
#EXPO_PUBLIC_DEV_API_HOST=192.168.0.10
#EXPO_PUBLIC_DEV_API_PORT=8080

# 운영 API URL. 비워두면 앱 기본값 사용.
# 실제 주소는 팀 노션의 인프라 문서에서 확인하세요.
#EXPO_PUBLIC_PROD_API_BASE_URL=https://api.example.com

# ── 로컬 도구 ─────────────────────────────────────────────────

# Slack 인커밍 웹훅 (디지스트/이슈 알림용)
# https://api.slack.com/messaging/webhooks 에서 발급
# SLACK_WEBHOOK_URL=


# ===============================================================
# [2] backend/.env 로 복사 — Spring Boot prod (AWS RDS + R2 + JWT)
# ===============================================================

# 프로파일 (dev: H2 + 로컬 파일, prod: RDS + R2)
#SPRING_PROFILES_ACTIVE=prod

# AWS RDS MySQL
#DB_HOST=offmode-db.xxxxxxxx.ap-northeast-2.rds.amazonaws.com
#DB_PORT=3306
#DB_NAME=offmode
#DB_USERNAME=
#DB_PASSWORD=

# Cloudflare R2
#R2_ACCESS_KEY=
#R2_SECRET_KEY=
#R2_ENDPOINT=
#R2_BUCKET=
#R2_PUBLIC_URL=

# JWT
#JWT_SECRET=

# CORS — 도메인 확정 전엔 비워두거나 임시로 * (운영 시 도메인 명시)
#CORS_ALLOWED_ORIGINS=
